# Copy this file to backend/.env and replace the placeholders.

# Google Sheets target spreadsheet ID
GOOGLE_SHEETS_SPREADSHEET_ID=your_google_spreadsheet_id_here

# Choose one of the two service-account options below.

# Option A: absolute path to the Google service-account JSON file
GOOGLE_SERVICE_ACCOUNT_FILE=C:\\path\\to\\service-account.json

# Option B: raw JSON content in a single line
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# Supabase project
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Optional; defaults to public
SUPABASE_SCHEMA=public

# Optional operational settings

# Additional CORS origins for the materials backoffice frontend.
# Keep the local Vite defaults and add any extra origin as a comma-separated list when needed.
# BACKOFFICE_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://192.168.1.50:8000

# Optional absolute path to a built frontend/dist directory.
# If omitted, the backend will try ../frontend/dist automatically.
# BACKOFFICE_FRONTEND_DIST_DIR=C:\\path\\to\\Dashboard\\frontend\\dist

# Set to true only if you explicitly do NOT want FastAPI to serve the built frontend.
# BACKOFFICE_DISABLE_FRONTEND_SERVING=false
